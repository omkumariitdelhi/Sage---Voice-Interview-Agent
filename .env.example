# Copy this file to `.env` and fill in real values. Never commit `.env`.
# All values below are read by app/config.py via os.environ — no secrets are
# ever hard-coded in source.

# --- Interviewer LLM (called through LiteLLM) ---
# Var name kept as OPENROUTER_* for historical reasons -- app/config.py and
# app/gateway/llm.py treat this as opaque, provider-agnostic config (LiteLLM
# dispatches purely off the model string below), so no code change was
# needed when the provider moved off OpenRouter. Put your real Anthropic
# API key here.
OPENROUTER_API_KEY=
# Any LiteLLM-recognized model string works here, swappable without a code
# change. Default below: Claude Haiku 4.5 (Anthropic) -- fast, cheap, and a
# reliable instruction-follower for this app's JSON-mode grading/feedback
# calls. An OpenRouter model string (e.g. openrouter/<provider>/<model>)
# also works if you'd rather route through OpenRouter instead.
OPENROUTER_MODEL=claude-haiku-4-5-20251001

# --- Speech (Deepgram, STT + TTS) ---
DEEPGRAM_API_KEY=
# LiteLLM model string. Format: deepgram/<model>. Swappable without code
# changes; default below is Deepgram's Nova-2 general model.
DEEPGRAM_MODEL=deepgram/nova-2
# Deepgram Aura-2 TTS voice/model id. Format: [modelname]-[voicename]-[language]
# (NOT a litellm model string -- litellm==1.89.2 has no Deepgram speech
# provider, so this is called via direct HTTP against Deepgram's own
# /v1/speak REST endpoint; see app/gateway/tts.py). Swappable without code
# changes; default below ("Thalia") is a clear, natural English voice.
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
